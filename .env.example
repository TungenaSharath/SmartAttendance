# ── Server ────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Security ──────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRY_HOURS=24

# ── Face Recognition ──────────────────
ARCFACE_MODEL=buffalo_l
SIM_THRESHOLD=0.45
DET_CONFIDENCE=0.5

# ── Frontend ──────────────────────────
VITE_API_URL=http://localhost:8000

# ── CORS (comma-separated origins) ────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
